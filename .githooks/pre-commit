#!/usr/bin/env bash
#
# pre-commit — 명시 버전(explicit version) 표준 강제 훅.
#
# 어떤 플러그인의 파일이 스테이징됐는데 그 플러그인의
# plugins/<name>/.claude-plugin/plugin.json 의 "version" 이 직전 커밋(HEAD)과
# 동일하다면(= 올리지 않았다면), patch 버전을 자동으로 +1 하고 다시 스테이징한다.
#
# - 명시 버전 방식에서는 version 을 올려야만 사용자 측 /plugin update 로 갱신되므로,
#   "파일만 고치고 버전은 그대로" 인 커밋을 막기 위한 안전장치다.
# - 이미 버전을 올렸거나(HEAD와 다름), 신규 플러그인(HEAD에 없음)이면 그대로 둔다.

repo_root="$(git rev-parse --show-toplevel)" || exit 0
cd "$repo_root" || exit 0

# 정의 파일 검증기 실행.
#
# 빌드가 없는 저장소이므로 이 훅이 유일한 자동 검증 지점이다.
# ERROR 가 있으면 커밋을 막고, WARN 은 출력만 하고 통과시킨다.
# 우회가 필요하면 SKIP_VALIDATE=1 git commit ... 또는 --no-verify.
run_validators() {
  [ -n "$SKIP_VALIDATE" ] && return 0
  command -v node >/dev/null 2>&1 || {
    echo "pre-commit: node 없음 — 정의 검증 건너뜀"
    return 0
  }
  [ -f scripts/validate-all.js ] || return 0

  if ! node scripts/validate-all.js; then
    echo ""
    echo "pre-commit: 정의 검증 실패 — 커밋을 중단한다."
    echo "            우회하려면 SKIP_VALIDATE=1 git commit ... 를 쓴다."
    return 1
  fi
  return 0
}

get_version() {
  grep -oE '"version"[[:space:]]*:[[:space:]]*"[^"]*"' \
    | head -n1 \
    | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/'
}

# 스테이징된 파일에서 영향받은 플러그인 이름 수집 (삭제 포함 → diff-filter 미지정)
plugins_changed="$(
  git diff --cached --name-only \
    | grep -E '^plugins/[^/]+/' \
    | sed -E 's#^plugins/([^/]+)/.*#\1#' \
    | sort -u
)"

if [ -z "$plugins_changed" ]; then
  run_validators
  exit $?
fi

while IFS= read -r plugin; do
  [ -z "$plugin" ] && continue
  manifest="plugins/$plugin/.claude-plugin/plugin.json"
  [ -f "$manifest" ] || continue   # 매니페스트 없는 디렉토리는 건너뜀

  head_ver="$(git show "HEAD:$manifest" 2>/dev/null | get_version)"
  staged_ver="$(git show ":$manifest" 2>/dev/null | get_version)"

  # 신규 플러그인(직전 커밋에 매니페스트 없음)은 그대로 둔다
  [ -z "$head_ver" ] && continue

  # 이미 버전이 바뀌었으면 통과
  if [ -n "$staged_ver" ] && [ "$staged_ver" != "$head_ver" ]; then
    continue
  fi

  # 버전 미변경 → patch +1.
  #
  # 치환은 node 로 한다. 과거 `sed -E "0,/re/ s//repl/"` 를 썼으나 `0,/re/` 는
  # GNU sed 확장이라 macOS 의 BSD sed 에서 에러 없이 조용히 no-op 되고 exit 0 을
  # 반환했다 — 그 결과 파일은 안 바뀌는데 아래 로그는 "올렸다"고 찍혀, macOS 에서
  # 커밋마다 버전이 소리 없이 누락됐다. node 는 검증기도 이미 전제하는 런타임이다.
  if ! command -v node >/dev/null 2>&1; then
    echo "pre-commit: node 없음 — $plugin version 자동 상승 불가. 수동으로 올린 뒤 다시 커밋하세요." >&2
    exit 1
  fi

  new_ver="$(node -e '
    const fs = require("fs"), p = process.argv[1];
    const s = fs.readFileSync(p, "utf8");
    const m = s.match(/"version"\s*:\s*"([^"]*)"/);
    if (!m) process.exit(2);
    const [a, b, c] = m[1].split(".");
    const nv = `${a}.${b}.${Number(c) + 1}`;
    fs.writeFileSync(p, s.replace(/("version"\s*:\s*")[^"]*(")/, `$1${nv}$2`));
    process.stdout.write(nv);
  ' "$manifest")"

  # 조용한 실패 재발 방지 — 파일이 실제로 new_ver 로 바뀌었는지 확인한 뒤에만 진행한다.
  if [ -z "$new_ver" ] || [ "$(get_version < "$manifest")" != "$new_ver" ]; then
    echo "pre-commit: $plugin version 자동 상승 실패 — 수동으로 올린 뒤 다시 커밋하세요." >&2
    exit 1
  fi
  git add "$manifest"
  echo "pre-commit: $plugin version $head_ver -> $new_ver (파일 변경됨, version 미수정 → 자동 상승)"
done <<EOF
$plugins_changed
EOF

# 버전 상승까지 끝난 뒤 검증한다 — 훅이 방금 고친 plugin.json 도 검사 대상이다.
run_validators
exit $?
